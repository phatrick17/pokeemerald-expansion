script Phenac_Verde_Battle_1 {
    lock
    faceplayer
    applymovement(OBJ_EVENT_ID_NPC_FOLLOWER, moves(
        face_left
    ))
    waitmovement
    msgbox(format("Sorry to break it to you, but I'm not about to let you pass.\p"
        "Or do you have this idea that you can take me in a battle?"), MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        msgbox(format("Wahaha!\p"
            "Well, of course!\n"
            "I'm vastly superior to the other two!"), MSGBOX_DEFAULT)
        release
        end
    }
    msgbox(format("Wahaha!\n"
        "Who's going to beat me?\p"
        "You are?!\n"
        "Don't be crying out of regret later!"), MSGBOX_DEFAULT)
    trainerbattle_no_intro(TRAINER_GABRIELLE_1,
        format("Verde: Y-You...You're tough!\n"
               "Can't blame them for losing earlier!"))
    removeobject(PHENAC_BAYLEEF)
    msgbox(format("{RIVAL}: What was that strange POKéMON?\p"
        "What did you people do to it?!\p"
        "Verde: It's a POKéMON that we turned into a fighting machine by artificially closing the door to its heart."), MSGBOX_DEFAULT)
    closemessage
    applymovement(OBJ_EVENT_ID_NPC_FOLLOWER, Common_Movement_ExclamationMark)
    playse(SE_PIN)
    waitse
    msgbox(format("{RIVAL}: You artificially closed the door to that poor POKéMON's heart?!\p"
        "Verde: Humph. Knowing that's not going to help you do anything!"), MSGBOX_DEFAULT)
    closemessage
    applymovement(PHENAC_VERDE_OUTSIDE_1, moves(
        walk_fast_left * 7
    ))
    waitmovement
    removeobject(PHENAC_VERDE_OUTSIDE_1)
    applymovement(OBJ_EVENT_ID_NPC_FOLLOWER, moves(
        face_player
    ))
    waitmovement
    msgbox(format("{RIVAL}: I know!\n"
    "When I was little, I heard about that.\p"
    "They say that if any POKéMON closes the door to its heart, it can be gradually reopened by battling together with it.\p"
    "{PLAYER}, let's go. Those guys are probably headed for PYRITE TOWN.\p"
    "After all, it was in PYRITE that they captured me."), MSGBOX_DEFAULT)
    setflag(FLAG_PHENAC_CITY_CIPHER_TRIO)
    release
    end
}

