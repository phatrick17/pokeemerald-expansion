// ---------------------------------------------------------
// Phenac_GuyMart_Dialogue_1 (Guy in front of mart)
// ---------------------------------------------------------
script Phenac_GuyMart_Dialogue_1 {
	lock
	faceplayer
    msgbox(format("If you're still traveling, you should\n"
        "stock up on supplies at the shop there.\p"
        "I recommend it.\n"
        "After all, it's my hou...\l"
        "Er... Ahem!\p"
        "Uh... Well, anyway, that shop has\n"
        "the best reputation around these parts!"), MSGBOX_DEFAULT)
	release
    end
}

// ---------------------------------------------------------
// Phenac_OldManDrig_Dialogue_1 (Old Man in front of right house)
// Flag-gated: show this script pre-defeat, switch to post-defeat script after
// ---------------------------------------------------------
script Phenac_Drig1 {
    if (flag(FLAG_DEFEAT_DRIG)) {
		call(Phenac_OldManDrig_Dialogue_2)
	} else {
		call(Phenac_OldManDrig_Dialogue_1)
	}
}


script Phenac_OldManDrig_Dialogue_1 {
	lock
	faceplayer
    msgbox(format("What fine weather this is!\n"
        "It's truly a perfect sort of day for\l"
        "a POKéMON battle.\p"
        "So, young one, how about indulging\n"
        "this old man? Let us battle."), MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        msgbox(format("Oh? How boring.\n"
            "You young people today…\l"
            "You have no gumption, I say."), MSGBOX_DEFAULT)
        release
        end
    }
    msgbox(format("All right!"), MSGBOX_DEFAULT)
    trainerbattle_no_intro(TRAINER_GRUNT_AQUA_HIDEOUT_2,
        format("Woah! I've got to concede this one lad!"))
    msgbox(format("DRIG: Ah, yes.\n"
        "You're young, but you've got a bit\l"
        "of spine!"), MSGBOX_DEFAULT)
	setflag(FLAG_DEFEAT_DRIG)
	release
    end
}

// Post-defeat (use flag check to swap to this)
script Phenac_OldManDrig_Dialogue_2 {
	lock
	faceplayer
    msgbox(format("DRIG: Why, you're just like me when\n"
        "I was young!\l"
        "Well done, indeed."), MSGBOX_DEFAULT)
	release
    end
}

// ---------------------------------------------------------
// Phenac_LadyTopRight_Dialogue_1 (Lady top right of bottom-right house)
// ---------------------------------------------------------
script Phenac_LadyTopRight_Dialogue_1 {
	lock
	faceplayer
    msgbox(format("Oh, are you traveling?\n"
        "Aww, I envy you!\p"
        "Is it a journey to become an expert\n"
        "trainer?\l"
        "Or a quest to meet POKéMON?\l"
        "Either way, you make me jealous!"), MSGBOX_DEFAULT)
	release
    end
}

// ---------------------------------------------------------
// Phenac_DudeGym_Dialogue_1 (Dude in front of gym)
// ---------------------------------------------------------
script Phenac_DudeGym_Dialogue_1 {
	lock
	faceplayer
    if (flag(FLAG_POKEBALLS_UNLOCKED)) {
        lock
        faceplayer
        msgbox(format("I saw a bunch of scary-looking people going towards the Mayor's house.\p"
        "But it won't matter if those guys do something bad.\p"
        "I'm sure Justy won't let them get away with anything!"
        ), MSGBOX_DEFAULT)
        release
        end
    }
    msgbox(format("Um ... I ...\n"
        "I really look up to Justy, the Leader\l"
        "of the Pregym.\p"
        "He's really cool!\n"
        "Of course, he's really a tough trainer\l"
        "at POKéMON battles, too!"), MSGBOX_DEFAULT)
	release
    end
}

// ---------------------------------------------------------
// Phenac_OldLadyMayor_Dialogue_1 (Old Lady in front of Mayor House)
// ---------------------------------------------------------
script Phenac_OldLadyMayor_Dialogue_1 {
	lock
	faceplayer
    if (flag(FLAG_MAP_UNLOCK_PYRITE)) {
        msgbox(format(
            "Oh? You were safe?\n"
            "The MAYOR wasn't home, either, I hear. All's well that ends well!"), MSGBOX_DEFAULT)
        release
        end
    }
    if (flag(FLAG_POKEBALLS_UNLOCKED)) {
        msgbox(format("My goodness! It's terrible!\p"
            "A big group of shady looking men marched into the MAYOR's house!"
        ), MSGBOX_DEFAULT)
        release
        end
    }
    msgbox(format("That large house is the MAYOR's\n"
        "home.\p"
        "If something concerns you while\n"
        "you're traveling, you should visit\l"
        "the MAYOR for his advice."), MSGBOX_DEFAULT)
	release
    end
}

// ---------------------------------------------------------
// Phenac_DudeStairs_Dialogue_1 (Dude top of stairs, next to right exit)
// ---------------------------------------------------------
script Phenac_DudeStairs_Dialogue_1 {
	lock
	faceplayer
    msgbox(format("This town was peaceful before\n"
        "but lately, it's been turning rougher.\p"
        "It's because of the thugs that live\n"
        "in Pyrite Town, which is the next\l"
        "town over.\p"
        "They've been showing up here.\p"
        "I don't want to have anything to do\n"
        "with them.\p"
        "Let sleeping dogs lie; that's what\n"
        "I say!"), MSGBOX_DEFAULT)
release
    end
}

// ---------------------------------------------------------
// Phenac_Zigzagoon_Dialogue_1
// ---------------------------------------------------------
script Phenac_Zigzagoon_Dialogue_1 {
	lock
	faceplayer
    playmoncry(SPECIES_ZIGZAGOON, CRY_MODE_NORMAL)
    msgbox(format("Gwonn!"), MSGBOX_DEFAULT)
	release
	applymovement(PHENAC_ZIG_1, moves(
        face_left
	))
    end
}

// ---------------------------------------------------------
// Phenac_SkaterKaib_Dialogue_1 (Skater top left)
// ---------------------------------------------------------

script Phenac_Kaib1 {
    if (flag(FLAG_DEFEAT_KAIB)) {
		call(Phenac_SkaterKaib_Dialogue_2)
	} else {
		call(Phenac_SkaterKaib_Dialogue_1)
	}
}
script Phenac_SkaterKaib_Dialogue_1 {
	lock
	faceplayer
    msgbox(format("I'm no good at schoolwork, but I'm\n"
        "pretty hot stuff at POKéMON battles.\p"
        "You're a trainer, too, aren't you?\n"
        "Let's duke it out!\l"
        "Let's battle!"), MSGBOX_YESNO)
    if (var(VAR_RESULT) == NO) {
        msgbox(format("Awww, you cheapskate!"), MSGBOX_DEFAULT)
        release
        end
    }
    msgbox(format("All right! Here we come,\n"
        "and there's no holding back!"),
        MSGBOX_DEFAULT)
    trainerbattle_no_intro(TRAINER_GRUNT_AQUA_HIDEOUT_3,
        format("KAIB: Ouch, no!\n"
            "That wasn't supposed to happen!"))
    msgbox(format("KAIB: Big guy, you're tough.\n"
        "I want you to have this since you're\l"
        "so good."), MSGBOX_DEFAULT)
    giveitem(ITEM_TM_TORMENT)
	setflag(FLAG_DEFEAT_KAIB)
    release
    end
}

// Post-defeat
script Phenac_SkaterKaib_Dialogue_2 {
    lock
	faceplayer
    msgbox(format("KAIB: Big guy, you're tough.\n"
        "I hope that TM comes in handy!"), MSGBOX_DEFAULT)
    release
    end
}

// ---------------------------------------------------------
// Phenac_GuyStadium_Dialogue_1 (Guy next to stadium)
// ---------------------------------------------------------
script Phenac_GuyStadium_Dialogue_1 {
    lock
	faceplayer
    if (flag(FLAG_PHENAC_PHENAC_SNAGEM_DEFEATED_1)) {
        msgbox(format("Hi!\n"
            "Did you know?!"), MSGBOX_YESNO)
        if (var(VAR_RESULT) == YES) {
            msgbox(format("Isn't it terrifying!"), MSGBOX_DEFAULT)
        } else {
            msgbox(format("My, you're awfully calm!\p"
                "They tell me that Team Snagem appeared here a little while ago!\p"
                "That's terrifying! I must be careful!\p"
                "I mustn't let them steal away my precious POKéMON!"), MSGBOX_DEFAULT)
        }
        release
        end
    }
    msgbox(format("Hi!\n"
        "Did you know?!"), MSGBOX_YESNO)
    if (var(VAR_RESULT) == YES) {
        msgbox(format("Isn't it amazing!"), MSGBOX_DEFAULT)
    } else {
        msgbox(format("They say that Team Snagem's\n"
            "hideout was blown up!\p"
            "Who could have done such a thing?"), MSGBOX_DEFAULT)
    }
    release
    end
}

script Phenac_Jigglypuff_Dialogue_1 {
    lock
	faceplayer
    playmoncry(SPECIES_JIGGLYPUFF, CRY_MODE_NORMAL)
    msgbox(format("Pururuun."), MSGBOX_DEFAULT)
    release
	applymovement(PHENAC_JIGGLY, moves(
        face_down
	))
    end
}

//END NPC SCRIPTS

script Phenac_Show_Runner1 {
	clearflag(FLAG_PHENAC_RUNNER)
	release
	end
}


//Nascour First Encounter
script Phenac_Nascour_Encounter_1{
    if (flag(FLAG_PHENAC_NASCOUR_1)) {
        release
        end
    }
    lockall
    applymovement(OBJ_EVENT_ID_PLAYER, Common_Movement_ExclamationMark)
	playse(SE_PIN)
    applymovement(OBJ_EVENT_ID_NPC_FOLLOWER, Common_Movement_ExclamationMark)
	waitse
    waitmovement(0)
    hidefollowernpc
    delay(15)
	applymovement(OBJ_EVENT_ID_PLAYER, moves(
		walk_right
		face_left
	))
    waitmovement(0)
	addobject(PHENAC_NASCOUR_1)
	playse(SE_EXIT)
	applymovement(PHENAC_NASCOUR_1, moves(
		walk_down * 1
		face_right
	))
    waitmovement
    delay(30)
	applymovement(PHENAC_NASCOUR_1, moves(
		face_right
	))
    waitmovement
    msgbox(format("???: Hm?\n"
        "I'd guess you're a traveling trainer?\p"
        "Hm...\n"
        "I like what I see in your expression.\l"
        "Fufufu...\p"
        "I have a feeling I may see you again\n"
        "somewhere."), MSGBOX_DEFAULT)
    closemessage
	applymovement(PHENAC_NASCOUR_1, moves(
		walk_left * 7
	))
    waitmovement
    removeobject(PHENAC_NASCOUR_1)
    setflag(FLAG_PHENAC_NASCOUR_1)
    releaseall
    end

}

script Phenac_Team_Snagem_First_Encounter_Stadium {
    fadescreen(FADE_TO_BLACK)
    setobjectxy(PHENAC_JIGGLY, 11, 0)
    setobjectxy(PHENAC_FISHER_GUY, 11, 0)
    removeobject(PHENAC_JIGGLY)
    removeobject(PHENAC_FISHER_GUY)
    lockall
	addobject(PHENAC_RUI_STADIUM_1)
	addobject(PHENAC_SNAGEM_GRUNT_1)
	addobject(PHENAC_SNAGEM_GRUNT_2)
	addobject(PHENAC_SNAGEM_GRUNT_3)
    playbgm(MUS_B_PALACE, FALSE)
	applymovement(OBJ_EVENT_ID_PLAYER, moves(
		walk_down
	))
    fadescreen(FADE_FROM_BLACK)
	applymovement(PHENAC_SNAGEM_GRUNT_2, moves(
		walk_up * 5
	))
	applymovement(PHENAC_SNAGEM_GRUNT_3, moves(
		walk_up * 5
	))
	applymovement(PHENAC_SNAGEM_GRUNT_1, moves(
		walk_up * 5
	))
    waitmovement
    msgbox(format("Hey, {PLAYER}!\n"
        "We finally found you!\l"
        "You filthy, double-crossing traitor!\p"
        "Wrecking the Hideout wasn't good\n"
        "enough for you?\p"
        "So you rip off the Snag Machine?\n"
        "You've got some nerve!"), MSGBOX_DEFAULT)
    closemessage
    applymovement(PHENAC_RUI_STADIUM_1, Common_Movement_ExclamationMark)
    playse(SE_PIN)
    waitse
	applymovement(PHENAC_RUI_STADIUM_1, moves(
		walk_left
        walk_down
	))
    waitmovement
    msgbox(format("{RIVAL}: Who are these people?\n"
        "Huh?\l"
        "Are they Team Snagem?\p"
        "{RIVAL}: And what did they mean\n"
        "by traitor?\p"
        "{PLAYER}...\n"
        "You mean...\p"
        "Grunt: That's right, pretty lady!\n"
        "He's from Team Snagem, just like us!\p"
        "But he's no ordinary member.\n"
        "He's a Snagger.\l"
        "He's the best in Team Snagem at\l"
        "snagging POKéMON without fail!"), MSGBOX_DEFAULT)
    closemessage
	applymovement(PHENAC_RUI_STADIUM_1, moves(
		face_right
	))
    waitmovement
    msgbox(format("{RIVAL}: No way! {PLAYER}?!\n"
        "Is that true?\p"
        "...\p"
        "{RIVAL}: So it is true!\n"
        "That's a little shocking!"), MSGBOX_DEFAULT)
    closemessage
	applymovement(PHENAC_RUI_STADIUM_1, moves(
		face_down
	))
	applymovement(PHENAC_SNAGEM_GRUNT_2, moves(
		walk_in_place_up
	))
    waitmovement
    msgbox(format("Grunt: Hey, {PLAYER}!\n"
        "Come on, hand it over!\p"
        "Give back the Snag Machine you ripped\n"
        "off from the Hideout!\p"
        "{RIVAL}: Snag Machine?\p"
        "{PLAYER}, do you really have\n"
        "something like that?"), MSGBOX_DEFAULT)
    closemessage
	applymovement(PHENAC_SNAGEM_GRUNT_2, moves(
		walk_in_place_up
	))
    waitmovement
    msgbox(format("Grunt: The Snag Machine was built\n"
        "for trainers.\p"
        "When a trainer puts the\n"
        "Snag Machine on, their Poké Balls are\l"
        "converted.\p"
        "Ordinary Poké Balls are turned into\n"
        "Snag Balls that can steal POKéMON\l"
        "from their trainers in battle."), MSGBOX_DEFAULT)
    closemessage
	applymovement(PHENAC_SNAGEM_GRUNT_3, moves(
		walk_in_place_left
	))
    msgbox(format("Grunt: Hey you blabbermouth!\n"
        "Keep that stuff secret!\p"
        "{RIVAL}: I get it, {PLAYER}.\n"
        "That's why these creeps are chasing\l"
        "after you."), MSGBOX_DEFAULT)
    closemessage
	applymovement(PHENAC_SNAGEM_GRUNT_3, moves(
		walk_in_place_up
	))
    waitmovement
    msgbox(format("Grunt: Creeps? What do you mean\n"
        "by creeps!\p"
        "Gah, this is getting us nowhere!\n"
        "If you won't give it up willingly,\l"
        "we'll take it back by force!"), MSGBOX_DEFAULT)
    trainerbattle_no_intro(TRAINER_GRUNT_SEAFLOOR_CAVERN_1,
        format("Wakin: No!\n"
               "I'm not good enough?!"))
    playbgm(MUS_B_ARENA, FALSE)
    msgbox(format("Wakin: Blast you {PLAYER}!\n"
        "Don't think this is over!\p"
        "We're going to get that Snag Machine\n"
        "back. Just you wait!"), MSGBOX_DEFAULT)
    closemessage
	applymovement(PHENAC_SNAGEM_GRUNT_2, moves(
		walk_down * 6
	))
	applymovement(PHENAC_SNAGEM_GRUNT_3, moves(
		walk_down * 6
	))
	applymovement(PHENAC_SNAGEM_GRUNT_1, moves(
		walk_down * 6
	))
    waitmovement
	applymovement(PHENAC_RUI_STADIUM_1, moves(
		face_right
	))
	applymovement(OBJ_EVENT_ID_PLAYER, moves(
		face_left
	))
    waitmovement
	removeobject(PHENAC_SNAGEM_GRUNT_1)
	removeobject(PHENAC_SNAGEM_GRUNT_2)
	removeobject(PHENAC_SNAGEM_GRUNT_3)
    msgbox(format("{RIVAL}: Well what do you know,\n"
        "{PLAYER}!\p"
        "So you're from Team Snagem.\p"
        "Oh right. To be accurate, I should\n"
        "say former Team Snagem.\p"
        "It's okay. {PLAYER}, it doesn't matter\n"
        "to me who you are.\p"
        "After all, you're my gallant prince\n"
        "who rescued me when I was in trouble.\p"
        "So, it doesn't matter.\n"
        "Besides, I thought up something after\l"
        "listening to those creeps.\p"
        "Listen, {PLAYER}, we should\n"
        "go shopping for some Poké Balls."), MSGBOX_DEFAULT)
	applymovement(PHENAC_RUI_STADIUM_1, moves(
		walk_right
	))
    waitmovement
	removeobject(PHENAC_RUI_STADIUM_1)
	applymovement(OBJ_EVENT_ID_PLAYER, moves(
		face_down
	))
    setvar(VAR_PHENAC_CITY_STATE, 3)
    setflag(FLAG_PHENAC_PHENAC_SNAGEM_DEFEATED_1)
    releaseall
    end
}

script Phenac_City_Lady_Needs_Help_1 {
    lock
    applymovement(OBJ_EVENT_ID_PLAYER, Common_Movement_ExclamationMark)
    playse(SE_PIN)
    waitse
    applymovement(OBJ_EVENT_ID_PLAYER, moves(
    face_up
	))
    applymovement(PHENAC_LADY_1, moves(
	walk_fast_left * 3
    walk_fast_down * 5
	))
    waitmovement
    msgbox(format("Oh! It's you two!\n"
    "Something terrible's happening!\p"
    "A whole lot of scary men came here!\n"
    "I think I even saw those two creeps\l"
    "who took off in the truck earlier!"), MSGBOX_DEFAULT)
    closemessage
    applymovement(PHENAC_LADY_1, moves(
	walk_up * 3
    face_down
    ))
    waitmovement
    setvar(VAR_PHENAC_CITY_STATE, 5)
    release
    end
}

