    playbgm(MUS_AQUA_MAGMA_HIDEOUT, FALSE)
    special(Special_OpenCustomMap)
    waitstate
    releaseall
    fadedefaultbgm
	applymovement(OBJ_EVENT_ID_PLAYER, moves(
		walk_up
	))
    waitmovement(0)
    end
}