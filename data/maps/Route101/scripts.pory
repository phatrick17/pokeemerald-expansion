script OPEN_WORLD_MAP_ENTER_Right {
    lockall
    playbgm(MUS_AQUA_MAGMA_HIDEOUT, FALSE)
    special(Special_OpenCustomMap)
    waitstate
    releaseall
    fadedefaultbgm
	applymovement(OBJ_EVENT_ID_PLAYER, moves(
		walk_left
	))
    waitmovement(0)
    end
}

script OPEN_WORLD_MAP_ENTER_Left {
    lockall
    playbgm(MUS_AQUA_MAGMA_HIDEOUT, FALSE)
    special(Special_OpenCustomMap)
    waitstate
    releaseall
    fadedefaultbgm
	applymovement(OBJ_EVENT_ID_PLAYER, moves(
		walk_right
	))
    waitmovement(0)
    end
}

